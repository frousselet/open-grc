SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Reverse proxy: trusted origins for CSRF (include scheme)
# CSRF_TRUSTED_ORIGINS=https://grc.example.com

POSTGRES_DB=open_grc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Optional – auto-create a super-admin on first startup
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=changeme
# DJANGO_SUPERUSER_FIRST_NAME=Admin
# DJANGO_SUPERUSER_LAST_NAME=

# Optional – "Ask Cairn" AI assistant (local Ollama sidecar)
# Requires: docker compose --profile ai up -d
#           docker compose exec ollama ollama pull qwen3:1.7b
# AI_ASSISTANT_ENABLED=True
# AI_ASSISTANT_OLLAMA_URL=http://ollama:11434
# AI_ASSISTANT_MODEL=qwen3:1.7b
